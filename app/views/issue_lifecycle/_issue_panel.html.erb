<% lifecycle = IssueLifecycleCalculator.new(issue).calculate %>
<% status_times = lifecycle[:status_times] %>
<% total = lifecycle[:total_time].to_f %>

<% if total > 0 && status_times.any? %>
  <hr />
  <div id="issue-lifecycle-panel" class="box">
    <h3 class="icon icon-issue">
      <a href="#" onclick="var el = document.getElementById('issue-lifecycle-body'); if(el.style.display === 'none'){ el.style.display = ''; } else { el.style.display = 'none'; } return false;">
        <%= l(:label_lifecycle) %> – <%= l(:label_time_in_status) %>
      </a>
    </h3>

    <div id="issue-lifecycle-body">
      <p><strong><%= l(:field_issue) %> #<%= lifecycle[:issue_id] %> – <%= h(lifecycle[:issue_subject]) %></strong></p>

      <div class="lifecycle-bar-wrapper" style="border: 1px solid #ccc; height: 22px; display: flex; width: 100%; max-width: 700px; margin-bottom: 8px; border-radius:3px; overflow:hidden; background-color:#f5f5f5;">
        <% status_times.each_with_index do |(status_name, seconds), idx| %>
          <% width = (seconds.to_f / total * 100).round(1) %>
          <% next if width <= 0 %>
          <% color = %w(#4caf50 #2196f3 #ff9800 #f44336 #9c27b0 #009688 #795548)[idx % 7] %>
          <div title="<%= "#{status_name}: #{distance_of_time_in_words(Time.now, Time.now - seconds)} (#{format_hours(seconds / 3600.0)} h, #{width}%)" %>"
               style="background-color:<%= color %>; width:<%= width %>%; position:relative;">
            <% if width >= 10 %>
              <span style="position:absolute; right:4px; top:2px; font-size:10px; color:#fff; text-shadow:0 0 2px rgba(0,0,0,0.6);">
                <%= "#{width}%" %>
              </span>
            <% end %>
          </div>
        <% end %>
      </div>

      <ul class="lifecycle-legend" style="list-style:none; padding-left:0; margin:0 0 8px 0;">
        <% status_times.each_with_index do |(status_name, seconds), idx| %>
          <% color = %w(#4caf50 #2196f3 #ff9800 #f44336 #9c27b0 #009688 #795548)[idx % 7] %>
          <li style="display:inline-block; margin-right:12px;">
            <span style="display:inline-block; width:10px; height:10px; background-color:<%= color %>; margin-right:4px;"></span>
            <strong><%= status_name %></strong>:
            <%= distance_of_time_in_words(Time.now, Time.now - seconds) %>
            (<%= format_hours(seconds / 3600.0) %>)
          </li>
        <% end %>
      </ul>

      <p>
        <strong><%= l(:label_total_time) %>:</strong>
        <%= distance_of_time_in_words(Time.now, Time.now - total) %>
        (<%= format_hours(total / 3600.0) %>)
      </p>
    </div>
  </div>
<% end %>

